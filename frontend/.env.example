# ===========================================================================
# .env.example — Copy this file to .env and fill in your real values.
# NEVER commit your real .env to version control.
# ===========================================================================

# Supabase — get these from your Supabase project: Settings > API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Google Gemini — get your key from https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here
